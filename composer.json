{
    "name": "andremellow/laravel-nightwatch-github",
    "description": "Forward signed Laravel Nightwatch issue webhooks to synchronized GitHub Issues.",
    "keywords": ["laravel", "nightwatch", "github", "issues", "webhook", "monitoring"],
    "license": "MIT",
    "type": "library",
    "require": {
        "php": "^8.2",
        "illuminate/bus": "^11.0|^12.0|^13.0",
        "illuminate/cache": "^11.0|^12.0|^13.0",
        "illuminate/database": "^11.0|^12.0|^13.0",
        "illuminate/http": "^11.0|^12.0|^13.0",
        "illuminate/queue": "^11.0|^12.0|^13.0",
        "illuminate/routing": "^11.0|^12.0|^13.0",
        "illuminate/support": "^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "laravel/pint": "^1.24",
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "pestphp/pest": "^3.8|^4.0",
        "pestphp/pest-plugin-laravel": "^3.2|^4.0"
    },
    "autoload": {
        "psr-4": {
            "Andremellow\\NightwatchGithub\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Andremellow\\NightwatchGithub\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Andremellow\\NightwatchGithub\\NightwatchGithubServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "pest",
        "format": "pint",
        "format:test": "pint --test"
    },
    "config": {
        "allow-plugins": {
            "pestphp/pest-plugin": true
        },
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
